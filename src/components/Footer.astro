---
import { FORMATS } from "../lib/formats.js";
const year = 2026;
---

<footer class="footer-root">
  <div class="page-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="brand-row">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="22" height="22">
              <defs>
                <linearGradient id="fg1" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#007cf0" />
                  <stop offset="50%" stop-color="#7928ca" />
                  <stop offset="100%" stop-color="#ff0080" />
                </linearGradient>
              </defs>
              <rect x="2" y="2" width="28" height="28" rx="7" fill="url(#fg1)" />
              <path d="M10 21 L14 14 L18 19 L22 11" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </svg>
          </span>
          <span class="brand-name">Image Convertor</span>
        </div>
        <p class="footer-tag t-body-sm">
          Free online image conversion. Your files never leave your browser.
        </p>
      </div>

      <div class="footer-col">
        <h4 class="t-caption-mono">Convert to</h4>
        <ul>
          {FORMATS.map((f) => (
            <li><a href={`/png-to-${f.id}`}>PNG → {f.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="t-caption-mono">Convert from</h4>
        <ul>
          {FORMATS.map((f) => (
            <li><a href={`/${f.id}-to-png`}>{f.label} → PNG</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="t-caption-mono">Company</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/#formats">All formats</a></li>
          <li><a href="/sitemap-index.xml">Sitemap</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="t-body-sm">© {year} realonlineruler.com — Image Convertor</span>
      <span class="t-caption-mono">Made for the open web</span>
    </div>
  </div>
</footer>

<style>
  .footer-root {
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding: 64px 0 32px;
    margin-top: 96px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
  }
  .footer-col h4 + ul,
  .footer-col ul { min-width: 0; }
  .footer-col a { word-break: break-word; }
  .footer-brand .brand-row {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .brand-name {
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
  }
  .footer-tag {
    color: var(--color-body);
    max-width: 280px;
    margin-top: 12px;
  }
  .footer-col h4 {
    color: var(--color-mute);
    margin: 0 0 16px;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    color: var(--color-body);
    text-decoration: none;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: -0.01em;
    transition: color 0.15s ease;
  }
  .footer-col a:hover { color: var(--color-ink); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-hairline);
    color: var(--color-mute);
  }

  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-root { padding: 48px 0 28px; margin-top: 64px; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; gap: 28px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 8px; margin-top: 32px; }
    .footer-tag { max-width: 100%; }
  }
</style>
