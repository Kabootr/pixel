---
const pathname = Astro.url.pathname;
const isActive = (p: string) => pathname === p || pathname.startsWith(p + "/");
---

<header class="nav-root">
  <div class="page-container nav-inner">
    <a href="/" class="brand" aria-label="PixelMorph home">
      <span class="brand-mark" aria-hidden="true">
        <!-- Tiny mesh-gradient logo mark -->
        <svg viewBox="0 0 32 32" width="22" height="22">
          <defs>
            <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#007cf0" />
              <stop offset="50%" stop-color="#7928ca" />
              <stop offset="100%" stop-color="#ff0080" />
            </linearGradient>
          </defs>
          <rect x="2" y="2" width="28" height="28" rx="7" fill="url(#g1)" />
          <path d="M10 21 L14 14 L18 19 L22 11" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
        </svg>
      </span>
      <span class="brand-name">PixelMorph</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      <div class="nav-dropdown">
        <button
          type="button"
          class:list={["nav-link", "nav-dropdown-trigger", (isActive("/resize") || isActive("/compress") || isActive("/crop") || isActive("/adjust") || isActive("/editor")) && "is-active"]}
          aria-haspopup="true"
          aria-expanded="false"
          id="nav-tools-trigger"
        >
          Tools
          <svg class="caret" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <div class="nav-dropdown-menu" id="nav-tools-menu" role="menu">
          <a class="nav-dropdown-item nav-item-featured" href="/editor" role="menuitem">
            <span class="nav-item-title">
              Editor
              <span class="nav-item-badge">NEW</span>
            </span>
            <span class="nav-item-desc">All tools, one canvas, local library</span>
          </a>
          <a class="nav-dropdown-item" href="/" role="menuitem">
            <span class="nav-item-title">Convert format</span>
            <span class="nav-item-desc">PNG, JPG, WebP, GIF, SVG, ICO, TIFF</span>
          </a>
          <a class="nav-dropdown-item" href="/resize" role="menuitem">
            <span class="nav-item-title">Resize</span>
            <span class="nav-item-desc">% · exact pixels · fit to box</span>
          </a>
          <a class="nav-dropdown-item" href="/compress" role="menuitem">
            <span class="nav-item-title">Compress</span>
            <span class="nav-item-desc">Quality slider · size delta · auto-format</span>
          </a>
          <a class="nav-dropdown-item" href="/crop" role="menuitem">
            <span class="nav-item-title">Crop</span>
            <span class="nav-item-desc">Free · 1:1 · 16:9 · 9:16 · drag handles</span>
          </a>
          <a class="nav-dropdown-item" href="/adjust" role="menuitem">
            <span class="nav-item-title">Tweak colours</span>
            <span class="nav-item-desc">Brightness · contrast · hue · presets</span>
          </a>
        </div>
      </div>
      <a class:list={["nav-link", isActive("/about") && "is-active"]} href="/about">About</a>
      <a class:list={["nav-link", isActive("/privacy") && "is-active"]} href="/privacy">Privacy</a>
    </nav>

    <div class="nav-ctas">
      <button
        type="button"
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle dark mode"
        title="Toggle theme"
      >
        <svg class="icon-sun" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
      <a
        class="nav-cta nav-cta-ghost"
        href="https://github.com/Kabootr/pixel"
        target="_blank"
        rel="noopener"
        aria-label="PixelMorph on GitHub"
      >GitHub</a>
      <a class="nav-cta nav-cta-primary" href="/#converter">Open Converter →</a>
    </div>

    <button class="nav-burger" id="nav-burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile" id="nav-mobile" hidden>
    <span class="nav-mobile-section t-caption-mono">Tools</span>
    <a href="/editor">Editor · all-in-one</a>
    <a href="/">Convert format</a>
    <a href="/resize">Resize</a>
    <a href="/compress">Compress</a>
    <a href="/crop">Crop</a>
    <a href="/adjust">Tweak colours</a>
    <a href="/about">About</a>
    <a href="/privacy">Privacy</a>
    <button type="button" class="theme-toggle theme-toggle-mobile" id="theme-toggle-mobile" aria-label="Toggle dark mode">
      <span class="theme-toggle-label">Theme</span>
      <span class="theme-toggle-value" id="theme-toggle-value">Light</span>
    </button>
    <a href="https://github.com/Kabootr/pixel" target="_blank" rel="noopener">GitHub</a>
    <a href="/#converter" class="btn-primary-sm" style="justify-content:center;">Open Converter</a>
  </div>
</header>

<style>
  .nav-root {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-nav-bg, rgba(255, 255, 255, 0.85));
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--color-hairline);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 16px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-ink);
    text-decoration: none;
    min-width: 0;
    flex-shrink: 0;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .brand-name {
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
  }
  .nav-link {
    color: var(--color-body);
    text-decoration: none;
    font-size: 14px;
    line-height: 20px;
    padding: 6px 12px;
    border-radius: 999px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .nav-link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }
  .nav-link.is-active { color: var(--color-ink); }

  /* Dropdown menu */
  .nav-dropdown { position: relative; }
  .nav-dropdown-trigger {
    background: none;
    border: none;
    cursor: pointer;
    font: inherit;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .nav-dropdown-trigger .caret {
    transition: transform 0.15s ease;
    margin-top: 1px;
    opacity: 0.7;
  }
  .nav-dropdown-trigger[aria-expanded="true"] .caret { transform: rotate(180deg); }
  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    padding: 8px;
    min-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
    box-shadow:
      0 2px 2px rgba(0, 0, 0, 0.04),
      0 8px 16px -4px rgba(0, 0, 0, 0.08),
      0 24px 32px -8px rgba(0, 0, 0, 0.06);
  }
  .nav-dropdown-menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .nav-dropdown-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .nav-dropdown-item:hover { background-color: var(--color-canvas-soft); }
  .nav-item-title {
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .nav-item-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    background: linear-gradient(135deg, var(--color-grad-develop-start), var(--color-grad-preview-end));
    color: white;
    padding: 1px 6px;
    border-radius: 999px;
  }
  .nav-item-featured {
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    margin-bottom: 4px;
  }
  .nav-item-desc {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 16px;
    color: var(--color-mute);
    letter-spacing: 0.02em;
  }

  .nav-ctas {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .nav-cta-ghost {
    color: var(--color-ink);
    text-decoration: none;
    border: 1px solid var(--color-hairline);
  }
  .nav-cta-ghost:hover {
    background-color: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }
  .nav-cta-primary {
    background-color: var(--color-ink);
    color: var(--color-on-primary);
    text-decoration: none;
  }
  .nav-cta-primary:hover { background-color: var(--color-primary-hover, #2a2a2a); }

  /* Theme toggle */
  .theme-toggle {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    background-color: transparent;
    border: 1px solid var(--color-hairline);
    color: var(--color-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease;
    flex-shrink: 0;
  }
  .theme-toggle:hover {
    background-color: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }
  /* Show sun in dark mode, moon in light mode */
  .theme-toggle .icon-sun { display: none; }
  .theme-toggle .icon-moon { display: inline-block; }
  :global([data-theme="dark"]) .theme-toggle .icon-sun { display: inline-block; }
  :global([data-theme="dark"]) .theme-toggle .icon-moon { display: none; }
  .nav-burger {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: none;
    border: 1px solid var(--color-hairline);
    border-radius: 8px;
    width: 40px;
    height: 40px;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
  }
  .nav-burger span {
    display: block;
    width: 16px;
    height: 1.5px;
    background-color: var(--color-ink);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav-burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 8px 16px 20px;
    gap: 4px;
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
  }
  .nav-mobile a {
    color: var(--color-ink);
    text-decoration: none;
    padding: 14px 4px;
    font-size: 16px;
    border-bottom: 1px solid var(--color-hairline);
  }
  .nav-mobile a:last-child {
    border-bottom: none;
    margin-top: 12px;
    padding: 12px 16px;
  }
  .nav-mobile-section {
    color: var(--color-mute);
    padding: 16px 4px 6px;
    border-bottom: none;
  }

  .theme-toggle-mobile {
    width: 100%;
    height: auto;
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--color-hairline);
    padding: 14px 4px;
    background: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font: inherit;
    font-size: 16px;
    color: var(--color-ink);
    cursor: pointer;
  }
  .theme-toggle-value {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-mute);
  }

  @media (max-width: 860px) {
    .nav-links, .nav-ctas { display: none; }
    .nav-burger { display: flex; }
    .nav-mobile.is-open { display: flex; }
  }
  @media (max-width: 380px) {
    .brand-name { font-size: 14px; }
  }
</style>

<script>
  // Tools dropdown (desktop nav)
  const toolsTrigger = document.getElementById("nav-tools-trigger");
  const toolsMenu = document.getElementById("nav-tools-menu");
  const closeTools = () => {
    toolsMenu?.classList.remove("is-open");
    toolsTrigger?.setAttribute("aria-expanded", "false");
  };
  toolsTrigger?.addEventListener("click", (e) => {
    e.stopPropagation();
    const open = toolsMenu?.classList.toggle("is-open");
    toolsTrigger.setAttribute("aria-expanded", String(!!open));
  });
  document.addEventListener("click", (e) => {
    if (!toolsMenu?.classList.contains("is-open")) return;
    if (toolsMenu.contains(e.target as Node) || toolsTrigger?.contains(e.target as Node)) return;
    closeTools();
  });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeTools(); });

  const burger = document.getElementById("nav-burger");
  const mobile = document.getElementById("nav-mobile");
  const close = () => {
    mobile?.classList.remove("is-open");
    burger?.setAttribute("aria-expanded", "false");
    if (mobile) mobile.hidden = true;
  };
  burger?.addEventListener("click", () => {
    const open = mobile?.classList.toggle("is-open");
    burger.setAttribute("aria-expanded", String(open));
    if (mobile) mobile.hidden = !open;
  });
  // Close menu when an in-page link is tapped
  mobile?.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
  // Close on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });
  // Close if the viewport widens past the mobile breakpoint
  const mql = window.matchMedia("(min-width: 861px)");
  mql.addEventListener?.("change", (e) => { if (e.matches) close(); });

  // Theme toggle — pairs with the FOUC-prevention script in Layout.astro
  const themeLabel = (theme: string) => theme.charAt(0).toUpperCase() + theme.slice(1);
  const currentTheme = () =>
    document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
  const setTheme = (theme: "light" | "dark") => {
    document.documentElement.setAttribute("data-theme", theme);
    try { localStorage.setItem("pm-theme", theme); } catch (e) { /* ignore */ }
    const mobileValue = document.getElementById("theme-toggle-value");
    if (mobileValue) mobileValue.textContent = themeLabel(theme);
  };
  const toggleTheme = () => setTheme(currentTheme() === "dark" ? "light" : "dark");
  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);
  // Sync mobile label on first paint
  const mobileValue = document.getElementById("theme-toggle-value");
  if (mobileValue) mobileValue.textContent = themeLabel(currentTheme());
</script>
