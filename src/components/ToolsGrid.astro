---
const TOOLS = [
  {
    href: "/editor",
    title: "Editor (all-in-one)",
    blurb: "One canvas, all five tools, plus a local image library that persists across sessions. Backup as a ZIP, restore on any browser.",
    icon: "editor",
    eyebrow: "New · Editor",
    featured: true,
  },
  {
    href: "/",
    title: "Convert format",
    blurb: "PNG, JPG, WebP, GIF, SVG, ICO, TIFF — any pair, any direction.",
    icon: "convert",
    eyebrow: "Convert",
  },
  {
    href: "/resize",
    title: "Resize",
    blurb: "By percent, exact pixels, or long-side fit. Lock aspect, bulk apply.",
    icon: "resize",
    eyebrow: "Resize",
  },
  {
    href: "/compress",
    title: "Compress",
    blurb: "Quality slider, auto-format picker, per-file size delta — bytes, not vibes.",
    icon: "compress",
    eyebrow: "Compress",
  },
  {
    href: "/crop",
    title: "Crop",
    blurb: "Free crop or aspect lock (1:1, 16:9, 9:16 and more). Drag or type pixels.",
    icon: "crop",
    eyebrow: "Crop",
  },
  {
    href: "/adjust",
    title: "Tweak colours",
    blurb: "Brightness, contrast, hue, sepia, blur, grayscale. Live preview, six presets.",
    icon: "adjust",
    eyebrow: "Adjust",
  },
];

function iconSvg(name) {
  const stroke = `fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"`;
  switch (name) {
    case "editor":
      return `<svg viewBox="0 0 24 24" width="22" height="22" ${stroke}><rect x="3" y="3" width="18" height="18" rx="2.5"/><path d="M3 15h18"/><path d="M9 3v12"/></svg>`;
    case "convert":
      return `<svg viewBox="0 0 24 24" width="22" height="22" ${stroke}><path d="M7 4v6m-3-3l3-3 3 3"/><path d="M17 20v-6m3 3l-3 3-3-3"/><rect x="3" y="13" width="8" height="8" rx="1.5"/><rect x="13" y="3" width="8" height="8" rx="1.5"/></svg>`;
    case "resize":
      return `<svg viewBox="0 0 24 24" width="22" height="22" ${stroke}><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>`;
    case "compress":
      return `<svg viewBox="0 0 24 24" width="22" height="22" ${stroke}><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/></svg>`;
    case "crop":
      return `<svg viewBox="0 0 24 24" width="22" height="22" ${stroke}><path d="M6 2v14a2 2 0 0 0 2 2h14"/><path d="M18 22V8a2 2 0 0 0-2-2H2"/></svg>`;
    case "adjust":
      return `<svg viewBox="0 0 24 24" width="22" height="22" ${stroke}><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>`;
    default:
      return "";
  }
}
---

<section id="tools" class="tools-band">
  <div class="page-container">
    <header class="tools-header">
      <span class="t-caption-mono eyebrow">All PixelMorph tools</span>
      <h2 class="t-display-lg">Five tools. One promise: nothing uploads.</h2>
      <p class="t-body-lg sub">
        Every PixelMorph tool runs entirely inside your browser. Same shell, same speed, same privacy guarantee — pick the one that fits the job.
      </p>
    </header>

    <div class="tools-grid">
      {TOOLS.map((t) => (
        <a class:list={["tool-card", "card-lg", "elev-2", t.featured && "tool-card-featured"]} href={t.href}>
          <span class="tool-icon" aria-hidden="true" set:html={iconSvg(t.icon)}></span>
          <header class="tool-card-head">
            <span class="t-caption-mono tool-eyebrow">{t.eyebrow}</span>
          </header>
          <h3 class="t-display-sm">{t.title}</h3>
          <p class="t-body-md tool-blurb">{t.blurb}</p>
          <span class="tool-link">
            Open
            <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .tools-band { padding: 96px 0 0; }
  .tools-header {
    max-width: 720px;
    margin: 0 auto 48px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }
  .eyebrow { color: var(--color-mute); }
  .sub { color: var(--color-body); margin: 0; }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .tool-card:hover {
    transform: translateY(-2px);
  }
  .tool-icon {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background-color: var(--color-canvas-soft);
    color: var(--color-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }
  .tool-card-head { display: flex; align-items: center; }
  .tool-eyebrow { color: var(--color-mute); }
  .tool-blurb { color: var(--color-body); margin: 0; }
  .tool-link {
    margin-top: 8px;
    color: var(--color-ink);
    font-weight: 500;
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.15s ease;
  }
  .tool-card:hover .tool-link { gap: 10px; color: var(--color-link); }

  .tool-card-featured {
    position: relative;
    background: linear-gradient(135deg, rgba(0, 124, 240, 0.04), rgba(255, 0, 128, 0.04));
    border: 1px solid var(--color-hairline-strong);
  }
  .tool-card-featured::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: var(--radius-lg);
    padding: 1px;
    background: linear-gradient(135deg, var(--color-grad-develop-start), var(--color-grad-preview-end));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    opacity: 0.4;
  }
  .tool-card-featured .tool-eyebrow {
    background: linear-gradient(135deg, var(--color-grad-develop-start), var(--color-grad-preview-end));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: 500;
  }
  .tool-card-featured .tool-icon {
    background: linear-gradient(135deg, var(--color-grad-develop-start), var(--color-grad-preview-end));
    color: white;
  }

  @media (max-width: 980px) {
    .tools-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .tools-grid { grid-template-columns: 1fr; }
    .tools-band { padding-top: 56px; }
    .tools-header { margin-bottom: 32px; gap: 12px; }
  }
</style>
