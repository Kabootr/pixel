  .lock-btn[aria-pressed="false"] .lock-off { display: inline-block; }

  .sliders { display: flex; flex-direction: column; gap: 12px; }
  .slider-row { display: flex; flex-direction: column; gap: 6px; }
  .slider-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .slider-label { color: var(--color-ink); font-weight: 500; }
  .slider-value.is-changed { background-color: var(--color-ink); color: var(--color-on-primary); border-color: var(--color-ink); }

  /* Trust */
  .editor-trust {
