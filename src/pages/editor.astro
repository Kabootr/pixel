  .dim-field { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .dim-label { color: var(--color-mute); }
  .dim-input { font-family: var(--font-mono); height: 34px; }

  .px-row { display: flex; align-items: center; gap: 6px; }
  .px-row .input { flex: 1; min-width: 0; height: 34px; }
  .px-x { font-family: var(--font-mono); color: var(--color-mute); }
  .lock-btn {
