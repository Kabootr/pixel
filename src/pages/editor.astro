  }
  .toast {
    background-color: var(--color-canvas);
    color: var(--color-ink);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-size: 13px;
    min-width: 220px;
    max-width: 360px;
    box-shadow:
      0 8px 16px -4px rgba(0,0,0,0.12),
      0 24px 32px -8px rgba(0,0,0,0.10);
    pointer-events: auto;
    transform: translateX(8px);
    opacity: 0;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .toast.is-on { transform: translateX(0); opacity: 1; }
  .toast.tone-success { border-left: 3px solid #0a8a3e; }
  .toast.tone-error { border-left: 3px solid var(--color-error); }
  .toast.tone-info { border-left: 3px solid var(--color-link); }

  /* Drag-over state on the whole shell */
  body.dragging-image .stage { outline: 2px dashed var(--color-ink); outline-offset: -4px; }

  /* Mobile */
  @media (max-width: 1100px) {
    .editor-shell { grid-template-columns: 240px 1fr 280px; }
  }
  @media (max-width: 940px) {
    .editor-shell {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }
    .lib-rail, .tool-panel { min-height: 0; max-height: none; }
    .lib-grid { grid-template-columns: repeat(4, 1fr); max-height: 240px; }
  }
  @media (max-width: 560px) {
    .lib-grid { grid-template-columns: repeat(3, 1fr); }
    .tool-tabs { grid-template-columns: repeat(3, 1fr); }
    .tool-tab { padding: 8px 4px; }
    .stage-drop { padding: 40px 16px; }
    .stage { min-height: 360px; }
    .editor-header { padding-top: 20px; }
  }

  .drop-icon {
    width: 56px; height: 56px; border-radius: 999px;
    background-color: var(--color-canvas);
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--color-ink); margin-bottom: 16px;
    border: 1px solid var(--color-hairline); flex-shrink: 0;
  }
  .drop-sub { color: var(--color-body); margin: 8px 0 6px; }
  .drop-meta { color: var(--color-mute); margin-top: 8px; }
  .link-like { color: var(--color-link); text-decoration: underline; text-underline-offset: 2px; }
</style>

<script>
  import {
    decodeToCanvas,
    resizeCanvas,
    cropCanvas,
    applyAdjust,
    buildCssFilter,
    encodeRaster,
    humanFileSize,
    isImageFile,
    inferFormatId,
    replaceExt,
    rasterExtFor,
  } from "../lib/image-ops.js";
  import {
    listImages,
    getImage,
    addImage,
    updateImage,
    deleteImage,
    storageUsage,
    makeThumbnail,
  } from "../lib/storage.js";
  import { exportLibrary, importLibrary } from "../lib/backup.js";

  /* ─────────── Toast helper ─────────── */
  function toast(message: string, tone: "success" | "error" | "info" = "info") {
    const stack = document.getElementById("toast-stack");
    if (!stack) return;
    const el = document.createElement("div");
    el.className = `toast tone-${tone}`;
    el.textContent = message;
    stack.appendChild(el);
    requestAnimationFrame(() => el.classList.add("is-on"));
    setTimeout(() => {
      el.classList.remove("is-on");
      setTimeout(() => el.remove(), 250);
    }, 2800);
  }

  /* ─────────── DOM refs ─────────── */
  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T | null;

  const stage = $("stage")!;
  const stageEmpty = $("stage-empty")!;
  const stageDrop = $("stage-drop")!;
  const canvasWrap = $("stage-canvas-wrap")!;
  const canvasFrame = $("canvas-frame")!;
  const stageCanvas = $<HTMLCanvasElement>("stage-canvas")!;
  const stagePreview = $<HTMLImageElement>("stage-preview")!;
  const stageName = $("stage-name")!;
  const stageDims = $("stage-dims")!;
  const stageReset = $<HTMLButtonElement>("stage-reset")!;
  const stageSave = $<HTMLButtonElement>("stage-save")!;
  const stageExport = $<HTMLButtonElement>("stage-export")!;
  const cropMask = $("ed-crop-mask")!;
  const cropRect = $("ed-crop-rect")!;
  const libGrid = $("lib-grid")!;
  const libEmpty = $("lib-empty")!;
  const libUsage = $("lib-usage")!;
  const libAdd = $("lib-add")!;
  const libAddInput = $<HTMLInputElement>("lib-add-input")!;
  const libExport = $("lib-export")!;
  const libImport = $("lib-import")!;
  const libImportInput = $<HTMLInputElement>("lib-import-input")!;
  const libSearch = $<HTMLInputElement>("lib-search")!;

  /* ─────────── State ─────────── */
  type Adjust = {
    brightness: number; contrast: number; saturation: number;
    hue: number; sepia: number; grayscale: number; blur: number; invert: number;
  };
  const DEFAULT_ADJUST: Adjust = {
    brightness: 100, contrast: 100, saturation: 100,
    hue: 0, sepia: 0, grayscale: 0, blur: 0, invert: 0,
  };

  type State = {
    mode: "crop" | "resize" | "adjust" | "compress" | "convert";
    currentId: string | null;   // id in library, null if unsaved
    name: string;
    original: HTMLCanvasElement | null; // immutable source
    working: HTMLCanvasElement | null;  // current after applied edits
    crop: { x: number; y: number; w: number; h: number };
    cropAspect: number | null;
    adj: Adjust;                 // current preview/applied
    appliedAdj: Adjust;          // baseline (used for non-destructive reset)
    exportFormat: string;
    exportQuality: number;
    librarySearch: string;
    library: any[];              // list of meta
  };

  const state: State = {
    mode: "crop",
    currentId: null,
    name: "Untitled",
    original: null,
    working: null,
    crop: { x: 0, y: 0, w: 0, h: 0 },
    cropAspect: null,
    adj: { ...DEFAULT_ADJUST },
    appliedAdj: { ...DEFAULT_ADJUST },
    exportFormat: "png",
    exportQuality: 82,
    librarySearch: "",
    library: [],
  };

  /* ─────────── Helpers ─────────── */
  function clamp(v: number, min: number, max: number) {
    return Math.max(min, Math.min(max, v));
  }

  function downloadBlob(blob: Blob, name: string) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = name;
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function updateStageBadges() {
    stageName.textContent = state.name || "Untitled";
    if (state.working) {
      stageDims.textContent = `${state.working.width}×${state.working.height} · ${state.working === state.original ? "original" : "edited"}`;
    } else {
      stageDims.textContent = "";
    }
    const has = !!state.working;
    stageReset.disabled = !has;
    stageSave.disabled = !has;
    stageExport.disabled = !has;
  }

  function showStageEmpty(empty: boolean) {
    stageEmpty.hidden = !empty;
    canvasWrap.hidden = empty;
  }

  function updatePreviewFromWorking() {
    if (!state.working) return;
    // Use a downscaled data URL for the preview img to keep DOM cheap.
    const previewUrl = makePreviewUrl(state.working);
    stagePreview.src = previewUrl;
    // After the image actually paints, refresh crop overlay positions.
    stagePreview.onload = () => requestAnimationFrame(refreshCropOverlay);
  }

  function makePreviewUrl(src: HTMLCanvasElement) {
    const maxSide = 1600;
    const long = Math.max(src.width, src.height);
    if (long <= maxSide) return src.toDataURL("image/png");
    const scale = maxSide / long;
    const c = document.createElement("canvas");
    c.width = Math.round(src.width * scale);
    c.height = Math.round(src.height * scale);
    const ctx = c.getContext("2d")!;
    ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = "high";
    ctx.drawImage(src, 0, 0, c.width, c.height);
    return c.toDataURL("image/png");
  }

  function applyPreviewFilter() {
    stagePreview.style.filter = buildCssFilter(state.adj) || "none";
  }

  /* ─────────── Load image into stage ─────────── */
  async function loadImageFile(file: File) {
    if (!isImageFile(file)) {
      toast("That's not an image we recognise.", "error");
      return;
    }
    try {
      const src = await decodeToCanvas(file);
      state.original = src;
      state.working = src;
      state.name = file.name;
      state.currentId = null;
      state.adj = { ...DEFAULT_ADJUST };
      state.appliedAdj = { ...DEFAULT_ADJUST };
      state.exportFormat = pickFormatForSrc(file);
      syncControlsFromState();
      showStageEmpty(false);
      updateStageBadges();
      updatePreviewFromWorking();
      applyPreviewFilter();
      resetCropToFull();
      if (state.mode === "crop") refreshCropOverlay();
      markActiveLibCard();
    } catch (err: any) {
      toast(err?.message || "Could not decode that file.", "error");
    }
  }

  async function loadFromLibrary(id: string) {
    const rec = await getImage(id);
    if (!rec) return;
    const file = new File([rec.blob], rec.name, { type: rec.blob.type || `image/${rec.format}` });
    await loadImageFile(file);
    state.currentId = id;
    state.name = rec.name;
    updateStageBadges();
    markActiveLibCard();
  }

  function pickFormatForSrc(file: File) {
    const ext = inferFormatId(file);
    if (["png", "jpg", "webp"].includes(ext)) return ext;
    return "png";
  }

  /* ─────────── Mode switching ─────────── */
  document.querySelectorAll<HTMLButtonElement>(".tool-tab").forEach((btn) => {
    btn.addEventListener("click", () => switchMode(btn.dataset.mode as State["mode"]));
  });

  function switchMode(mode: State["mode"]) {
    state.mode = mode;
    document.querySelectorAll<HTMLButtonElement>(".tool-tab").forEach((b) => {
      b.setAttribute("aria-selected", String(b.dataset.mode === mode));
    });
    document.querySelectorAll<HTMLElement>(".mode-pane").forEach((p) => {
      p.hidden = p.dataset.pane !== mode;
    });
    const cropOn = mode === "crop" && !!state.working;
    cropMask.hidden = !cropOn;
    cropRect.hidden = !cropOn;
    if (cropOn) requestAnimationFrame(refreshCropOverlay);
  }

  /* ─────────── CROP mode ─────────── */
  const cropXEl = $<HTMLInputElement>("ed-crop-x")!;
  const cropYEl = $<HTMLInputElement>("ed-crop-y")!;
  const cropWEl = $<HTMLInputElement>("ed-crop-w")!;
  const cropHEl = $<HTMLInputElement>("ed-crop-h")!;

  document.querySelectorAll<HTMLButtonElement>(".format-pill[data-aspect]").forEach((p) => {
    p.addEventListener("click", () => {
      document.querySelectorAll<HTMLButtonElement>(".format-pill[data-aspect]").forEach((q) => q.setAttribute("aria-pressed", "false"));
      p.setAttribute("aria-pressed", "true");
      const v = p.dataset.aspect!;
      if (v === "free") state.cropAspect = null;
      else {
        const [a, b] = v.split(":").map(Number);
        state.cropAspect = a / b;
        applyAspectToCrop();
      }
    });
  });
  [cropXEl, cropYEl, cropWEl, cropHEl].forEach((el) => {
    el.addEventListener("input", () => {
      if (!state.working) return;
      const x = clamp(parseInt(cropXEl.value, 10) || 0, 0, state.working.width - 1);
      const y = clamp(parseInt(cropYEl.value, 10) || 0, 0, state.working.height - 1);
      const w = clamp(parseInt(cropWEl.value, 10) || 1, 1, state.working.width - x);
      const h = clamp(parseInt(cropHEl.value, 10) || 1, 1, state.working.height - y);
      state.crop = { x, y, w, h };
      refreshCropOverlay();
      syncCropInputs();
    });
  });

  $("ed-crop-reset")!.addEventListener("click", resetCropToFull);
  $("ed-crop-apply")!.addEventListener("click", () => {
    if (!state.working) return;
    const cropped = cropCanvas(state.working, state.crop);
    state.working = cropped;
    state.appliedAdj = { ...state.adj };
    updateStageBadges();
    updatePreviewFromWorking();
    resetCropToFull();
    toast("Crop applied to working image.", "success");
  });

  function resetCropToFull() {
    if (!state.working) return;
    if (state.cropAspect) {
      const srcA = state.working.width / state.working.height;
      let w, h;
      if (state.cropAspect > srcA) { w = state.working.width; h = Math.round(w / state.cropAspect); }
      else { h = state.working.height; w = Math.round(h * state.cropAspect); }
      state.crop = {
        x: Math.round((state.working.width - w) / 2),
        y: Math.round((state.working.height - h) / 2),
        w, h,
      };
    } else {
      state.crop = { x: 0, y: 0, w: state.working.width, h: state.working.height };
    }
    syncCropInputs();
    refreshCropOverlay();
  }

  function applyAspectToCrop() {
    if (!state.working || !state.cropAspect) return;
    const c = state.crop;
    let w = c.w;
    let h = Math.round(w / state.cropAspect);
    if (h > state.working.height - c.y) {
      h = state.working.height - c.y;
      w = Math.round(h * state.cropAspect);
    }
    if (w > state.working.width - c.x) {
      w = state.working.width - c.x;
      h = Math.round(w / state.cropAspect);
    }
    state.crop = { x: c.x, y: c.y, w, h };
    syncCropInputs();
    refreshCropOverlay();
  }

  function syncCropInputs() {
    cropXEl.value = String(state.crop.x);
    cropYEl.value = String(state.crop.y);
    cropWEl.value = String(state.crop.w);
    cropHEl.value = String(state.crop.h);
  }

  function refreshCropOverlay() {
    if (!state.working || state.mode !== "crop") return;
    const dispW = stagePreview.clientWidth;
    const dispH = stagePreview.clientHeight;
    if (!dispW || !dispH) return;
    // Place mask + rect within canvasFrame which is sized to the preview
    canvasFrame.style.width = `${dispW}px`;
    canvasFrame.style.height = `${dispH}px`;
    const scale = dispW / state.working.width;
    const left = state.crop.x * scale;
    const top = state.crop.y * scale;
    const w = state.crop.w * scale;
    const h = state.crop.h * scale;
    cropMask.style.width = `${dispW}px`;
    cropMask.style.height = `${dispH}px`;
    cropMask.style.clipPath = `polygon(
      0 0, 100% 0, 100% 100%, 0 100%, 0 0,
      ${left}px ${top}px,
      ${left}px ${top + h}px,
      ${left + w}px ${top + h}px,
      ${left + w}px ${top}px,
      ${left}px ${top}px
    )`;
    cropRect.style.left = `${left}px`;
    cropRect.style.top = `${top}px`;
    cropRect.style.width = `${w}px`;
    cropRect.style.height = `${h}px`;
  }

  // Crop drag interaction
  type DragMode = "move" | "nw" | "n" | "ne" | "e" | "se" | "s" | "sw" | "w" | null;
  let dragMode: DragMode = null;
  let dragStart = { px: 0, py: 0, c: { x: 0, y: 0, w: 0, h: 0 } };
  cropRect.addEventListener("pointerdown", (e: PointerEvent) => {
    const target = e.target as HTMLElement;
    const handle = target.dataset?.handle as DragMode | undefined;
    dragMode = handle ?? "move";
    dragStart = { px: e.clientX, py: e.clientY, c: { ...state.crop } };
    (e.target as Element).setPointerCapture?.(e.pointerId);
    e.preventDefault();
  });
  cropRect.addEventListener("pointermove", (e: PointerEvent) => {
    if (!dragMode || !state.working) return;
    const scale = stagePreview.clientWidth / state.working.width;
    const dx = (e.clientX - dragStart.px) / scale;
    const dy = (e.clientY - dragStart.py) / scale;
    const c = { ...dragStart.c };
    const sw = state.working.width;
    const sh = state.working.height;

    if (dragMode === "move") {
      c.x = clamp(c.x + dx, 0, sw - c.w);
      c.y = clamp(c.y + dy, 0, sh - c.h);
    } else {
      const fixedR = dragStart.c.x + dragStart.c.w;
      const fixedB = dragStart.c.y + dragStart.c.h;
      if (dragMode.includes("e")) c.w = clamp(dragStart.c.w + dx, 8, sw - c.x);
      if (dragMode.includes("w")) {
        const nx = clamp(dragStart.c.x + dx, 0, fixedR - 8);
        c.x = nx; c.w = fixedR - nx;
      }
      if (dragMode.includes("s")) c.h = clamp(dragStart.c.h + dy, 8, sh - c.y);
      if (dragMode.includes("n")) {
        const ny = clamp(dragStart.c.y + dy, 0, fixedB - 8);
        c.y = ny; c.h = fixedB - ny;
      }
      if (state.cropAspect) {
        if (dragMode === "e" || dragMode === "w") {
          c.h = c.w / state.cropAspect;
        } else if (dragMode === "n" || dragMode === "s") {
          c.w = c.h * state.cropAspect;
        } else {
          const newH = c.w / state.cropAspect;
          if (dragMode.includes("n")) c.y = fixedB - newH;
          c.h = newH;
        }
        c.w = clamp(c.w, 8, sw - c.x);
        c.h = clamp(c.h, 8, sh - c.y);
      }
    }
    state.crop = {
      x: Math.round(c.x),
      y: Math.round(c.y),
      w: Math.max(1, Math.round(c.w)),
      h: Math.max(1, Math.round(c.h)),
    };
    refreshCropOverlay();
    syncCropInputs();
  });
  const endDrag = (e: PointerEvent) => {
    dragMode = null;
    try { (e.target as Element).releasePointerCapture?.(e.pointerId); } catch {}
  };
  cropRect.addEventListener("pointerup", endDrag);
  cropRect.addEventListener("pointercancel", endDrag);

  /* ─────────── RESIZE mode ─────────── */
  const rsPercent = $<HTMLInputElement>("ed-rs-percent")!;
  const rsPercentVal = $("ed-rs-percent-value")!;
  const rsW = $<HTMLInputElement>("ed-rs-w")!;
  const rsH = $<HTMLInputElement>("ed-rs-h")!;
  const rsLock = $("ed-rs-lock")!;
  const rsFit = $<HTMLInputElement>("ed-rs-fit")!;
  const rsFitVal = $("ed-rs-fit-value")!;

  let rsMode: "percent" | "px" | "fit" = "percent";
  let rsAspectLock = true;
  let rsLastEdited: "w" | "h" = "w";

  document.querySelectorAll<HTMLButtonElement>(".format-pill[data-rmode]").forEach((p) => {
    p.addEventListener("click", () => {
      document.querySelectorAll<HTMLButtonElement>(".format-pill[data-rmode]").forEach((q) => q.setAttribute("aria-pressed", "false"));
      p.setAttribute("aria-pressed", "true");
      rsMode = p.dataset.rmode as any;
      document.querySelectorAll<HTMLElement>(".resize-field").forEach((el) => {
        el.hidden = el.dataset.rfield !== rsMode;
      });
    });
  });
  rsPercent.addEventListener("input", () => { rsPercentVal.textContent = `${rsPercent.value}%`; });
  rsFit.addEventListener("input", () => { rsFitVal.textContent = String(rsFit.value); });
  rsLock.addEventListener("click", () => {
    rsAspectLock = !rsAspectLock;
    rsLock.setAttribute("aria-pressed", String(rsAspectLock));
  });
  rsW.addEventListener("input", () => {
    rsLastEdited = "w";
    if (rsAspectLock && state.working) {
      const ratio = state.working.width / state.working.height;
      const w = parseInt(rsW.value, 10);
      if (w > 0) rsH.value = String(Math.round(w / ratio));
    }
  });
  rsH.addEventListener("input", () => {
    rsLastEdited = "h";
    if (rsAspectLock && state.working) {
      const ratio = state.working.width / state.working.height;
      const h = parseInt(rsH.value, 10);
      if (h > 0) rsW.value = String(Math.round(h * ratio));
    }
  });
  document.querySelectorAll<HTMLButtonElement>(".preset-pill[data-rpreset]").forEach((p) => {
    p.addEventListener("click", () => {
      const cfg = JSON.parse(p.dataset.rpreset!);
      if (cfg.mode === "percent") {
        rsMode = "percent";
        rsPercent.value = String(cfg.percent);
        rsPercentVal.textContent = `${cfg.percent}%`;
      } else if (cfg.mode === "fit") {
        rsMode = "fit";
        rsFit.value = String(cfg.maxSide);
        rsFitVal.textContent = String(cfg.maxSide);
      }
      document.querySelectorAll<HTMLButtonElement>(".format-pill[data-rmode]").forEach((q) => q.setAttribute("aria-pressed", String(q.dataset.rmode === rsMode)));
      document.querySelectorAll<HTMLElement>(".resize-field").forEach((el) => { el.hidden = el.dataset.rfield !== rsMode; });
    });
  });
  $("ed-rs-apply")!.addEventListener("click", () => {
    if (!state.working) return;
    let opts: any = undefined;
    if (rsMode === "percent") {
      const p = parseInt(rsPercent.value, 10);
      if (!p || p === 100) { toast("Resize is 100% — nothing to apply.", "info"); return; }
      opts = { mode: "percent", percent: p };
    } else if (rsMode === "px") {
      const w = parseInt(rsW.value, 10) || undefined;
      const h = parseInt(rsH.value, 10) || undefined;
      if (!w && !h) { toast("Set a target width or height.", "info"); return; }
      if (rsAspectLock) opts = rsLastEdited === "w" ? { mode: "px", width: w } : { mode: "px", height: h };
      else opts = { mode: "px", width: w, height: h };
    } else if (rsMode === "fit") {
      const m = parseInt(rsFit.value, 10);
      if (!m) { toast("Set a max side.", "info"); return; }
      opts = { mode: "fit", maxSide: m };
    }
    const resized = resizeCanvas(state.working, opts);
    if (resized === state.working) {
      toast("Image already matches that size.", "info");
      return;
    }
    state.working = resized;
    updateStageBadges();
    updatePreviewFromWorking();
    resetCropToFull();
    toast("Resize applied.", "success");
  });

  /* ─────────── ADJUST mode ─────────── */
  const adjSliders = Array.from(document.querySelectorAll<HTMLInputElement>("[id^='ed-aj-'][id$=brightness], [id^='ed-aj-'][id$=contrast], [id^='ed-aj-'][id$=saturation], [id^='ed-aj-'][id$=hue], [id^='ed-aj-'][id$=sepia], [id^='ed-aj-'][id$=grayscale], [id^='ed-aj-'][id$=blur], [id^='ed-aj-'][id$=invert]"));
  // simpler: query by pattern
  const adjKeys: (keyof Adjust)[] = ["brightness","contrast","saturation","hue","sepia","grayscale","blur","invert"];
  const adjEls: Record<string, HTMLInputElement> = {};
  const adjValEls: Record<string, HTMLElement> = {};
  for (const k of adjKeys) {
    adjEls[k] = $<HTMLInputElement>(`ed-aj-${k}`)!;
    adjValEls[k] = $(`ed-aj-v-${k}`)!;
    adjEls[k].addEventListener("input", () => {
      state.adj[k] = parseFloat(adjEls[k].value);
      const def = parseFloat(adjEls[k].dataset.default || "0");
      const num = k === "blur" ? state.adj[k] : Math.round(state.adj[k]);
      adjValEls[k].textContent = formatAdjValue(k, num);
      adjValEls[k].classList.toggle("is-changed", num !== def);
      clearActiveAdjPreset();
      applyPreviewFilter();
    });
  }

  function formatAdjValue(key: keyof Adjust, n: number) {
    if (key === "hue") return `${n}°`;
    if (key === "blur") return `${n}px`;
    return `${n}%`;
  }

  const ADJ_PRESETS: Record<string, Partial<Adjust>> = {
    vivid: { saturation: 140, contrast: 115 },
    mono: { saturation: 0, contrast: 110 },
    warm: { hue: -10, sepia: 30, contrast: 105 },
    cool: { hue: 15, saturation: 90 },
    dramatic: { contrast: 140, brightness: 95, saturation: 110 },
    soft: { contrast: 92, brightness: 105, blur: 0.5 },
  };
  document.querySelectorAll<HTMLButtonElement>(".preset-pill[data-apreset]").forEach((p) => {
    p.addEventListener("click", () => {
      const cfg = ADJ_PRESETS[p.dataset.apreset!];
      if (!cfg) return;
      state.adj = { ...DEFAULT_ADJUST, ...cfg };
      syncAdjSliders();
      document.querySelectorAll<HTMLElement>(".preset-pill[data-apreset]").forEach((b) => b.classList.remove("is-active"));
      p.classList.add("is-active");
      applyPreviewFilter();
    });
  });
  $("ed-aj-reset")!.addEventListener("click", () => {
    state.adj = { ...DEFAULT_ADJUST };
    syncAdjSliders();
    clearActiveAdjPreset();
    applyPreviewFilter();
  });
  $("ed-aj-apply")!.addEventListener("click", () => {
    if (!state.working) return;
    state.working = applyAdjust(state.working, state.adj);
    state.adj = { ...DEFAULT_ADJUST };
    state.appliedAdj = { ...DEFAULT_ADJUST };
    syncAdjSliders();
    applyPreviewFilter();
    updateStageBadges();
    updatePreviewFromWorking();
    resetCropToFull();
    toast("Adjustments baked into the working image.", "success");
  });

  function syncAdjSliders() {
    for (const k of adjKeys) {
      adjEls[k].value = String(state.adj[k]);
      const def = parseFloat(adjEls[k].dataset.default || "0");
      const num = k === "blur" ? state.adj[k] : Math.round(state.adj[k]);
      adjValEls[k].textContent = formatAdjValue(k, num);
      adjValEls[k].classList.toggle("is-changed", num !== def);
    }
  }
  function clearActiveAdjPreset() {
    document.querySelectorAll<HTMLElement>(".preset-pill[data-apreset]").forEach((b) => b.classList.remove("is-active"));
  }

  /* ─────────── COMPRESS mode ─────────── */
  const cpQ = $<HTMLInputElement>("ed-cp-q")!;
  const cpQv = $("ed-cp-q-value")!;
  cpQ.addEventListener("input", () => {
    state.exportQuality = parseInt(cpQ.value, 10);
    cpQv.textContent = String(state.exportQuality);
  });
  document.querySelectorAll<HTMLButtonElement>(".preset-pill[data-cpreset]").forEach((p) => {
    p.addEventListener("click", () => {
      state.exportQuality = parseInt(p.dataset.cpreset!, 10);
      cpQ.value = String(state.exportQuality);
      cpQv.textContent = String(state.exportQuality);
    });
  });

  /* ─────────── CONVERT mode ─────────── */
  document.querySelectorAll<HTMLButtonElement>(".format-pill[data-cformat]").forEach((p) => {
    p.addEventListener("click", () => {
      document.querySelectorAll<HTMLButtonElement>(".format-pill[data-cformat]").forEach((q) => q.setAttribute("aria-pressed", "false"));
      p.setAttribute("aria-pressed", "true");
      state.exportFormat = p.dataset.cformat!;
    });
  });

  function syncControlsFromState() {
    // Reflect state.exportFormat in convert pills
    document.querySelectorAll<HTMLButtonElement>(".format-pill[data-cformat]").forEach((q) => {
      q.setAttribute("aria-pressed", String(q.dataset.cformat === state.exportFormat));
    });
    cpQ.value = String(state.exportQuality);
    cpQv.textContent = String(state.exportQuality);
    syncAdjSliders();
    if (state.working) {
      rsW.value = String(state.working.width);
      rsH.value = String(state.working.height);
    }
  }

  /* ─────────── Top-bar actions ─────────── */
  stageReset.addEventListener("click", () => {
    if (!state.original) return;
    state.working = state.original;
    state.adj = { ...DEFAULT_ADJUST };
    state.appliedAdj = { ...DEFAULT_ADJUST };
    syncAdjSliders();
    applyPreviewFilter();
    updateStageBadges();
    updatePreviewFromWorking();
    resetCropToFull();
    toast("Reset to original.", "info");
  });

  stageName.addEventListener("click", () => {
    stageName.setAttribute("contenteditable", "true");
    stageName.focus();
    const range = document.createRange();
    range.selectNodeContents(stageName);
    const sel = window.getSelection();
    sel?.removeAllRanges(); sel?.addRange(range);
  });
  stageName.addEventListener("blur", commitRename);
  stageName.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Enter") { e.preventDefault(); stageName.blur(); }
    if (e.key === "Escape") { e.preventDefault(); stageName.textContent = state.name; stageName.blur(); }
  });
  async function commitRename() {
    stageName.setAttribute("contenteditable", "false");
    const next = (stageName.textContent || "").trim();
    if (!next || next === state.name) {
      stageName.textContent = state.name;
      return;
    }
    state.name = next;
    if (state.currentId) {
      await updateImage(state.currentId, { name: next });
      await refreshLibrary();
    }
  }

  stageSave.addEventListener("click", async () => {
    if (!state.working) return;
    stageSave.disabled = true;
    try {
      const blob = await encodeRaster(state.working, {
        format: state.exportFormat,
        quality: state.exportQuality,
      });
      const thumbnail = makeThumbnail(state.working);
      const targetExt = rasterExtFor(state.exportFormat);
      const finalName = replaceExt(state.name, targetExt);
      if (state.currentId) {
        await updateImage(state.currentId, {
          name: finalName,
          blob,
          width: state.working.width,
          height: state.working.height,
          format: state.exportFormat,
          thumbnail,
        });
        toast(`Saved updates to "${finalName}".`, "success");
      } else {
        const rec = await addImage({
          name: finalName,
          blob,
          width: state.working.width,
          height: state.working.height,
          format: state.exportFormat,
          thumbnail,
        });
        state.currentId = rec.id;
        toast(`Saved "${finalName}" to your library.`, "success");
      }
      state.name = finalName;
      updateStageBadges();
      await refreshLibrary();
    } catch (err: any) {
      toast(err?.message || "Save failed.", "error");
    } finally {
      stageSave.disabled = !state.working;
    }
  });

  stageExport.addEventListener("click", async () => {
    if (!state.working) return;
    stageExport.disabled = true;
    const label = stageExport.querySelector(".btn-label")!;
    const original = label.textContent;
    label.textContent = "Exporting…";
    try {
      const blob = await encodeRaster(state.working, {
        format: state.exportFormat,
        quality: state.exportQuality,
      });
      const targetExt = rasterExtFor(state.exportFormat);
      downloadBlob(blob, replaceExt(state.name || "pixelmorph", targetExt));
      toast(`Exported ${humanFileSize(blob.size)}.`, "success");
    } catch (err: any) {
      toast(err?.message || "Export failed.", "error");
    } finally {
      label.textContent = original;
      stageExport.disabled = !state.working;
    }
  });

  /* ─────────── Library actions ─────────── */
  libAdd.addEventListener("click", () => libAddInput.click());
  libAddInput.addEventListener("change", async () => {
    if (!libAddInput.files?.length) return;
    const files = Array.from(libAddInput.files);
    libAddInput.value = "";
    let lastId: string | null = null;
    for (const file of files) {
      if (!isImageFile(file)) continue;
      try {
        const canvas = await decodeToCanvas(file);
        const thumbnail = makeThumbnail(canvas);
        const fmt = inferFormatId(file);
        const rec = await addImage({
          name: file.name,
          blob: file,
          width: canvas.width,
          height: canvas.height,
          format: fmt,
          thumbnail,
        });
        lastId = rec.id;
      } catch (err) {
        console.error(err);
        toast(`Skipped "${file.name}".`, "error");
      }
    }
    await refreshLibrary();
    if (files.length > 0) {
      toast(`Added ${files.length} image${files.length === 1 ? "" : "s"}.`, "success");
      if (lastId && !state.working) await loadFromLibrary(lastId);
    }
  });

  libExport.addEventListener("click", async () => {
    try {
      const n = await exportLibrary();
      if (n === 0) toast("Library is empty — nothing to back up.", "info");
      else toast(`Backed up ${n} image${n === 1 ? "" : "s"}.`, "success");
    } catch (err: any) {
      toast(err?.message || "Backup failed.", "error");
    }
  });
  libImport.addEventListener("click", () => libImportInput.click());
  libImportInput.addEventListener("change", async () => {
    if (!libImportInput.files?.length) return;
    const file = libImportInput.files[0];
    libImportInput.value = "";
    try {
      const { imported, skipped } = await importLibrary(file);
      await refreshLibrary();
      toast(`Imported ${imported}${skipped ? `, skipped ${skipped} duplicate${skipped === 1 ? "" : "s"}` : ""}.`, "success");
    } catch (err: any) {
      toast(err?.message || "Import failed.", "error");
    }
  });

  libSearch.addEventListener("input", () => {
    state.librarySearch = libSearch.value.trim().toLowerCase();
    renderLibrary();
  });

  async function refreshLibrary() {
    state.library = await listImages();
    const used = await storageUsage();
    libUsage.textContent = humanFileSize(used);
    renderLibrary();
  }

  function renderLibrary() {
    const q = state.librarySearch;
    const items = q
      ? state.library.filter((m) => m.name.toLowerCase().includes(q))
      : state.library;
    libGrid.innerHTML = "";
    if (state.library.length === 0) {
      libGrid.appendChild(libEmpty);
      libEmpty.hidden = false;
      return;
    }
    if (items.length === 0) {
      const empty = document.createElement("p");
      empty.className = "lib-empty t-body-sm";
      empty.style.gridColumn = "1 / -1";
      empty.style.textAlign = "center";
      empty.style.padding = "16px";
      empty.style.color = "var(--color-mute)";
      empty.textContent = `No images match "${q}".`;
      libGrid.appendChild(empty);
      return;
    }
    for (const meta of items) {
      const card = document.createElement("div");
      card.className = "lib-card";
      if (meta.id === state.currentId) card.classList.add("is-active");
      card.dataset.id = meta.id;
      const thumbWrap = document.createElement("div");
      thumbWrap.className = "thumb-wrap";
      if (meta.thumbnail) {
        const img = document.createElement("img");
        img.src = meta.thumbnail; img.alt = "";
        thumbWrap.appendChild(img);
      }
      card.appendChild(thumbWrap);
      const metaBox = document.createElement("div");
      metaBox.className = "meta";
      const name = document.createElement("div");
      name.className = "name"; name.title = meta.name;
      name.textContent = meta.name;
      metaBox.appendChild(name);
      const sub = document.createElement("div");
      sub.className = "sub";
      sub.textContent = `${meta.width}×${meta.height} · ${humanFileSize(meta.size)}`;
      metaBox.appendChild(sub);
      card.appendChild(metaBox);

      const overlay = document.createElement("div");
      overlay.className = "lib-card-overlay";
      const dlBtn = document.createElement("button");
      dlBtn.title = "Download"; dlBtn.setAttribute("aria-label", "Download image");
      dlBtn.innerHTML = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`;
      dlBtn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const full = await getImage(meta.id);
        if (full) downloadBlob(full.blob, full.name);
      });
      const rmBtn = document.createElement("button");
      rmBtn.className = "danger";
      rmBtn.title = "Delete"; rmBtn.setAttribute("aria-label", "Delete image");
      rmBtn.innerHTML = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>`;
      rmBtn.addEventListener("click", async (e) => {
        e.stopPropagation();
        if (!confirm(`Delete "${meta.name}" from your library?`)) return;
        await deleteImage(meta.id);
        if (state.currentId === meta.id) {
          state.currentId = null;
        }
        await refreshLibrary();
        toast("Deleted.", "info");
      });
      overlay.appendChild(dlBtn);
      overlay.appendChild(rmBtn);
      card.appendChild(overlay);

      card.addEventListener("click", () => loadFromLibrary(meta.id));
      libGrid.appendChild(card);
    }
  }

  function markActiveLibCard() {
    document.querySelectorAll<HTMLElement>(".lib-card").forEach((el) => {
      el.classList.toggle("is-active", el.dataset.id === state.currentId);
    });
  }

  /* ─────────── Global drop / paste ─────────── */
  stageDrop.addEventListener("click", () => libAddInput.click());
  stageDrop.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === " ") { e.preventDefault(); libAddInput.click(); }
  });
  let dragDepth = 0;
  document.addEventListener("dragenter", (e) => {
    if (!e.dataTransfer?.types?.includes("Files")) return;
    dragDepth++;
    document.body.classList.add("dragging-image");
  });
  document.addEventListener("dragleave", () => {
    dragDepth = Math.max(0, dragDepth - 1);
    if (dragDepth === 0) document.body.classList.remove("dragging-image");
  });
  document.addEventListener("dragover", (e) => { e.preventDefault(); });
  document.addEventListener("drop", async (e) => {
    e.preventDefault();
    dragDepth = 0;
    document.body.classList.remove("dragging-image");
    const files = Array.from(e.dataTransfer?.files || []);
    if (!files.length) return;
    const first = files.find(isImageFile);
    if (!first) return;
    await loadImageFile(first);
  });
  document.addEventListener("paste", async (e) => {
    const items = (e as ClipboardEvent).clipboardData?.items;
    if (!items) return;
    for (const item of items) {
      if (item.kind === "file") {
        const f = item.getAsFile();
        if (f) { await loadImageFile(f); break; }
      }
    }
  });

  /* ─────────── Resize observer to keep crop overlay aligned ─────────── */
  const ro = new ResizeObserver(() => refreshCropOverlay());
  ro.observe(stagePreview);

  /* ─────────── Boot ─────────── */
  switchMode("crop");
  refreshLibrary();
</script>
