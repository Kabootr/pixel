  .crop-grid { position: absolute; inset: 0; pointer-events: none; }
  .crop-grid span { position: absolute; background-color: rgba(255,255,255,0.4); }
  .crop-grid span:nth-child(1) { left: 33.333%; top: 0; bottom: 0; width: 1px; }
  .crop-grid span:nth-child(2) { left: 66.667%; top: 0; bottom: 0; width: 1px; }
  .crop-grid span:nth-child(3) { top: 33.333%; left: 0; right: 0; height: 1px; }
