---
import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.astro";
import { toFaqPageSchema } from "../lib/faqData.js";

const title = "PixelMorph Editor — Browser-Native Image Studio";
const description =
  "All five PixelMorph tools in one canvas — crop, resize, compress, convert, and tweak colors. Save images to your local library that lives in your browser. Backup & restore as a zip.";
const keywords = [
  "image editor", "browser image editor", "free image editor",
  "private image editor", "local-first image editor", "image studio online",
  "indexeddb image library", "image backup", "pixelmorph editor",
  "crop resize compress in one tool",
].join(", ");

const siteUrl = "https://pixelmorph.app";
const pageUrl = `${siteUrl}/editor`;

const ASPECTS = [
  { id: "free", label: "Free" },
  { id: "1:1", label: "1:1" },
  { id: "4:3", label: "4:3" },
  { id: "3:2", label: "3:2" },
  { id: "16:9", label: "16:9" },
  { id: "9:16", label: "9:16" },
];

const RESIZE_PRESETS = [
  { label: "50%", mode: "percent", percent: 50 },
  { label: "25%", mode: "percent", percent: 25 },
  { label: "Long side 1080", mode: "fit", maxSide: 1080 },
  { label: "Long side 1920", mode: "fit", maxSide: 1920 },
];

const ADJ_SLIDERS = [
  { id: "brightness", label: "Brightness", min: 0, max: 200, def: 100, unit: "%" },
  { id: "contrast", label: "Contrast", min: 0, max: 200, def: 100, unit: "%" },
  { id: "saturation", label: "Saturation", min: 0, max: 200, def: 100, unit: "%" },
  { id: "hue", label: "Hue rotate", min: -180, max: 180, def: 0, unit: "°" },
  { id: "sepia", label: "Sepia", min: 0, max: 100, def: 0, unit: "%" },
  { id: "grayscale", label: "Grayscale", min: 0, max: 100, def: 0, unit: "%" },
  { id: "blur", label: "Blur", min: 0, max: 20, def: 0, unit: "px" },
  { id: "invert", label: "Invert", min: 0, max: 100, def: 0, unit: "%" },
];

const ADJ_PRESETS = ["Vivid", "Mono", "Warm", "Cool", "Dramatic", "Soft"];

const OUTPUT_FORMATS = [
  { id: "png", label: "PNG" },
  { id: "jpg", label: "JPG" },
  { id: "webp", label: "WebP" },
];

const faqs = [
  {
    q: "Where are my saved images actually stored?",
    a: "Inside this browser, in an IndexedDB database called \"pixelmorph\". Files never leave your machine — no upload, no server, no syncing. If you clear your browser data, the library is wiped. Use Backup to export a ZIP you can restore later.",
  },
  {
    q: "Does saving to the library upload my image?",
    a: "No. \"Save to library\" writes the image into your local IndexedDB only. The same is true for every edit you make in the editor.",
  },
  {
    q: "What does Backup do?",
    a: "Backup packages every image in your library plus a small manifest.json into a single ZIP that downloads to your device. Drop that ZIP into another browser (or after clearing data) via Import to restore the whole library.",
  },
  {
    q: "How big can the library get?",
    a: "Browsers typically give an origin 50% to 60% of available disk for IndexedDB. In practice that's tens of gigabytes on a modern laptop. PixelMorph shows current usage in the library header so you can keep an eye on it.",
  },
  {
    q: "Why is the editor a single page instead of separate tools?",
    a: "The editor is for the \"do several things to one image\" workflow — crop, then resize, then tweak colours, then export. The individual /crop, /resize, /compress and /adjust pages exist for focused single-task bulk work. Pick whichever matches what you're doing.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "PixelMorph Editor",
    url: pageUrl,
    applicationCategory: "MultimediaApplication",
    applicationSubCategory: "Image Editor",
    operatingSystem: "Any (browser-based)",
    description,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    featureList: [
      "Five tools in one canvas — crop, resize, compress, convert, tweak colours",
      "Local image library backed by IndexedDB",
      "Backup and restore the entire library as a single ZIP",
      "Search saved images by name",
      "100% client-side — files never leave your browser",
    ],
    browserRequirements: "Requires a modern browser with IndexedDB and Canvas API support",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "PixelMorph", item: `${siteUrl}/` },
      { "@type": "ListItem", position: 2, name: "Editor", item: pageUrl },
    ],
  },
  toFaqPageSchema(faqs),
];
---

<Layout title={title} description={description} keywords={keywords} jsonLd={jsonLd}>
  <section class="editor-page">
    <header class="editor-header page-container">
      <div class="editor-title">
        <span class="t-caption-mono editor-eyebrow">Editor · Private · Local-first</span>
        <h1 class="t-display-md">One canvas. Five tools. Zero uploads.</h1>
      </div>
      <div class="editor-header-actions">
        <button type="button" class="btn-secondary-sm" id="lib-import" title="Restore a backup">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Import
        </button>
        <button type="button" class="btn-secondary-sm" id="lib-export" title="Backup library">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Backup
        </button>
      </div>
    </header>

    <div class="editor-shell page-container">
      <!-- LIBRARY RAIL -->
      <aside class="lib-rail">
        <div class="lib-rail-head">
          <div class="lib-head-row">
            <h2 class="t-body-sm-strong">Your library</h2>
            <button type="button" class="lib-add-btn" id="lib-add" title="Add image">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
          </div>
          <p class="t-caption-mono lib-trust">
            Saved locally · <span id="lib-usage">0 B</span>
          </p>
          <div class="lib-search">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="search" class="lib-search-input" id="lib-search" placeholder="Search library…" />
          </div>
        </div>

        <div class="lib-grid" id="lib-grid">
          <!-- empty state -->
          <div class="lib-empty" id="lib-empty">
            <span class="lib-empty-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2.5"/><circle cx="9" cy="10" r="2"/><path d="m21 15-5-5L5 21"/></svg>
            </span>
            <p class="t-body-sm">No images yet</p>
            <p class="t-caption-mono lib-empty-hint">Drop one anywhere on the page to begin.</p>
          </div>
        </div>

        <input type="file" id="lib-add-input" accept=".png,.jpg,.jpeg,.webp,.gif,.svg,.tif,.tiff,image/*" multiple hidden />
        <input type="file" id="lib-import-input" accept=".zip,application/zip" hidden />
      </aside>

      <!-- CENTER STAGE -->
      <main class="stage-col">
        <div class="stage-toolbar">
          <span class="stage-name" id="stage-name" title="Click to rename">No image loaded</span>
          <span class="stage-dims t-caption-mono" id="stage-dims"></span>
          <div class="stage-toolbar-spacer"></div>
          <button type="button" class="btn-secondary-sm" id="stage-reset" disabled>Reset</button>
          <button type="button" class="btn-secondary-sm" id="stage-save" disabled>Save to library</button>
          <button type="button" class="btn-primary stage-export" id="stage-export" disabled>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span class="btn-label">Export</span>
          </button>
        </div>

        <div class="stage" id="stage">
          <!-- empty state: full-stage drop zone -->
          <div class="stage-empty" id="stage-empty">
            <div class="drop-zone stage-drop" id="stage-drop" role="button" tabindex="0">
              <div class="drop-icon">
                <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="17 8 12 3 7 8"/>
                  <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
              </div>
              <h3 class="t-display-sm">Drop an image, or pick from your library</h3>
              <p class="t-body-sm drop-sub">
                or <span class="link-like">browse</span> — PNG, JPG, WebP, GIF, SVG, TIFF
              </p>
              <p class="t-caption-mono drop-meta">
                100% client-side · saved to your browser, never uploaded
              </p>
            </div>
          </div>

          <!-- canvas stage with crop overlay -->
          <div class="stage-canvas-wrap" id="stage-canvas-wrap" hidden>
            <div class="canvas-frame" id="canvas-frame">
              <canvas class="stage-canvas" id="stage-canvas"></canvas>
              <img class="stage-preview" id="stage-preview" alt="" />
              <!-- Crop overlay (only visible in crop mode) -->
              <div class="crop-mask" id="ed-crop-mask" hidden></div>
              <div class="crop-rect" id="ed-crop-rect" hidden>
                <div class="crop-grid" aria-hidden="true">
                  <span></span><span></span><span></span><span></span>
                </div>
                <div class="crop-handle h-nw" data-handle="nw"></div>
                <div class="crop-handle h-n" data-handle="n"></div>
                <div class="crop-handle h-ne" data-handle="ne"></div>
                <div class="crop-handle h-e" data-handle="e"></div>
                <div class="crop-handle h-se" data-handle="se"></div>
                <div class="crop-handle h-s" data-handle="s"></div>
                <div class="crop-handle h-sw" data-handle="sw"></div>
                <div class="crop-handle h-w" data-handle="w"></div>
              </div>
            </div>
          </div>
        </div>
      </main>

      <!-- RIGHT TOOL PANEL -->
      <aside class="tool-panel" id="tool-panel">
        <div class="tool-tabs" role="tablist" aria-label="Editor mode">
          {["crop", "resize", "adjust", "compress", "convert"].map((m, i) => (
            <button
              type="button"
              class="tool-tab"
              role="tab"
              data-mode={m}
              aria-selected={i === 0 ? "true" : "false"}
            >{m.charAt(0).toUpperCase() + m.slice(1)}</button>
          ))}
        </div>

        <!-- CROP MODE -->
        <div class="mode-pane" data-pane="crop">
          <span class="t-caption-mono pane-label">Aspect ratio</span>
          <div class="format-pills">
            {ASPECTS.map((a, i) => (
              <button
                type="button"
                class="format-pill"
                data-aspect={a.id}
                aria-pressed={i === 0 ? "true" : "false"}
              >{a.label}</button>
            ))}
          </div>
          <div class="dims-row crop-dims">
            <div class="dim-field"><label class="t-caption-mono dim-label" for="ed-crop-x">X</label><input type="number" class="input dim-input" id="ed-crop-x" min="0" /></div>
            <div class="dim-field"><label class="t-caption-mono dim-label" for="ed-crop-y">Y</label><input type="number" class="input dim-input" id="ed-crop-y" min="0" /></div>
            <div class="dim-field"><label class="t-caption-mono dim-label" for="ed-crop-w">W</label><input type="number" class="input dim-input" id="ed-crop-w" min="1" /></div>
            <div class="dim-field"><label class="t-caption-mono dim-label" for="ed-crop-h">H</label><input type="number" class="input dim-input" id="ed-crop-h" min="1" /></div>
          </div>
          <div class="pane-actions">
            <button type="button" class="btn-secondary-sm" id="ed-crop-reset">Reset rect</button>
            <button type="button" class="btn-primary-sm" id="ed-crop-apply">Apply crop</button>
          </div>
        </div>

        <!-- RESIZE MODE -->
        <div class="mode-pane" data-pane="resize" hidden>
          <span class="t-caption-mono pane-label">Resize mode</span>
          <div class="format-pills">
            <button type="button" class="format-pill" data-rmode="percent" aria-pressed="true">By %</button>
            <button type="button" class="format-pill" data-rmode="px" aria-pressed="false">By pixels</button>
            <button type="button" class="format-pill" data-rmode="fit" aria-pressed="false">Fit to box</button>
          </div>

          <div class="resize-field" data-rfield="percent">
            <label class="t-body-sm pane-sublabel" for="ed-rs-percent">Scale <span class="quality-value" id="ed-rs-percent-value">100%</span></label>
            <input type="range" id="ed-rs-percent" class="range" min="5" max="400" value="100" step="1" />
          </div>
          <div class="resize-field" data-rfield="px" hidden>
            <label class="t-body-sm pane-sublabel">Dimensions</label>
            <div class="px-row">
              <input type="number" class="input" id="ed-rs-w" min="1" placeholder="W" />
              <span class="px-x">×</span>
              <input type="number" class="input" id="ed-rs-h" min="1" placeholder="H" />
              <button type="button" class="lock-btn" id="ed-rs-lock" aria-pressed="true" title="Lock aspect ratio">
                <svg class="lock-on" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
                <svg class="lock-off" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 7.5-2"/></svg>
              </button>
            </div>
          </div>
          <div class="resize-field" data-rfield="fit" hidden>
            <label class="t-body-sm pane-sublabel" for="ed-rs-fit">Max long side <span class="quality-value" id="ed-rs-fit-value">1920</span></label>
            <input type="range" id="ed-rs-fit" class="range" min="64" max="8192" value="1920" step="32" />
          </div>

          <div class="preset-pills mt-12">
            {RESIZE_PRESETS.map((p) => (
              <button type="button" class="preset-pill" data-rpreset={JSON.stringify(p)}>{p.label}</button>
            ))}
          </div>

          <div class="pane-actions">
            <button type="button" class="btn-primary-sm" id="ed-rs-apply">Apply resize</button>
          </div>
        </div>

        <!-- ADJUST MODE -->
        <div class="mode-pane" data-pane="adjust" hidden>
          <span class="t-caption-mono pane-label">Style presets</span>
          <div class="preset-pills">
            {ADJ_PRESETS.map((p) => (
              <button type="button" class="preset-pill" data-apreset={p.toLowerCase()}>{p}</button>
            ))}
          </div>
          <div class="sliders mt-12">
            {ADJ_SLIDERS.map((s) => (
              <div class="slider-row" data-slider={s.id}>
                <div class="slider-head">
                  <label class="t-body-sm slider-label" for={`ed-aj-${s.id}`}>{s.label}</label>
                  <span class="quality-value slider-value" id={`ed-aj-v-${s.id}`}>{s.def}{s.unit}</span>
                </div>
                <input
                  type="range"
                  class="range"
                  id={`ed-aj-${s.id}`}
                  min={s.min}
                  max={s.max}
                  value={s.def}
                  data-default={s.def}
                  step={s.id === "blur" ? "0.1" : "1"}
                />
              </div>
            ))}
          </div>
          <div class="pane-actions">
            <button type="button" class="btn-secondary-sm" id="ed-aj-reset">Reset</button>
            <button type="button" class="btn-primary-sm" id="ed-aj-apply">Apply adjustments</button>
          </div>
        </div>

        <!-- COMPRESS MODE -->
        <div class="mode-pane" data-pane="compress" hidden>
          <span class="t-caption-mono pane-label">Export quality</span>
          <div class="quality-row">
            <label class="t-body-sm pane-sublabel" for="ed-cp-q">
              Quality
              <span class="quality-value" id="ed-cp-q-value">82</span>
            </label>
            <input type="range" id="ed-cp-q" class="range" min="10" max="100" value="82" step="1" />
            <div class="quality-scale"><span>Tiny</span><span>Balanced</span><span>Lossless</span></div>
          </div>
          <p class="t-caption-mono pane-help">Affects JPG and WebP export. PNG is lossless.</p>
          <div class="preset-pills mt-12">
            <button type="button" class="preset-pill" data-cpreset="60">Tiny · q60</button>
            <button type="button" class="preset-pill" data-cpreset="72">Small · q72</button>
            <button type="button" class="preset-pill" data-cpreset="82">Balanced · q82</button>
            <button type="button" class="preset-pill" data-cpreset="92">High · q92</button>
          </div>
          <p class="t-caption-mono pane-help mt-12">
            Set quality, then hit Export. Compress doesn't modify the working image — it only changes the encode.
          </p>
        </div>

        <!-- CONVERT MODE -->
        <div class="mode-pane" data-pane="convert" hidden>
          <span class="t-caption-mono pane-label">Export format</span>
          <div class="format-pills" id="ed-cv-formats">
            {OUTPUT_FORMATS.map((f, i) => (
              <button type="button" class="format-pill" data-cformat={f.id} aria-pressed={i === 0 ? "true" : "false"}>{f.label}</button>
            ))}
          </div>
          <p class="t-caption-mono pane-help">
            Hit Export to download in the chosen format. Save to library re-saves using your current export settings.
          </p>
        </div>
      </aside>
    </div>

    <!-- Trust band -->
    <section class="page-container editor-trust">
      <p class="t-body-sm">
        <strong>Your images never leave this page.</strong> The library is stored in your browser's IndexedDB.
        Backup creates a ZIP with every image plus a small <code>manifest.json</code> — drop that ZIP back via Import to restore.
      </p>
    </section>

    <FAQ
      items={faqs}
      eyebrow="Editor FAQs"
      title="The editor & your library."
    />
  </section>

  <!-- Toast container -->
  <div class="toast-stack" id="toast-stack" aria-live="polite" aria-atomic="true"></div>
</Layout>

<style>
  .editor-page { padding-bottom: 32px; }

  .editor-header {
    padding-top: 32px;
    padding-bottom: 16px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .editor-eyebrow { color: var(--color-mute); display: block; margin-bottom: 6px; }
  .editor-title h1 { margin: 0; }
  .editor-header-actions { display: flex; gap: 8px; }

  .editor-shell {
    display: grid;
    grid-template-columns: 280px 1fr 320px;
    gap: 16px;
    align-items: stretch;
  }

  /* ─── LIBRARY RAIL ─── */
  .lib-rail {
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    min-height: 580px;
    max-height: 75vh;
    overflow: hidden;
  }
  .lib-rail-head {
    padding: 14px 14px 10px;
    border-bottom: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .lib-head-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .lib-trust { color: var(--color-mute); }
  .lib-add-btn {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    border: 1px solid var(--color-hairline);
    background-color: var(--color-canvas);
    color: var(--color-body);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .lib-add-btn:hover { border-color: var(--color-hairline-strong); color: var(--color-ink); }

  .lib-search {
    position: relative;
    display: flex;
    align-items: center;
  }
  .lib-search svg {
    position: absolute;
    left: 10px;
    color: var(--color-mute);
    pointer-events: none;
  }
  .lib-search-input {
    width: 100%;
    height: 34px;
    padding: 0 10px 0 32px;
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--color-ink);
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .lib-search-input:focus {
    border-color: var(--color-ink);
    box-shadow: 0 0 0 3px rgba(23, 23, 23, 0.06);
  }

  .lib-grid {
    flex: 1;
    overflow-y: auto;
    padding: 12px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    align-content: start;
  }

  .lib-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 28px 16px;
    color: var(--color-mute);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .lib-empty-icon {
    width: 40px; height: 40px;
    border-radius: 999px;
    border: 1px solid var(--color-hairline);
    background-color: var(--color-canvas-soft);
    color: var(--color-body);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .lib-empty p { margin: 0; }
  .lib-empty-hint { color: var(--color-mute); }

  .lib-card {
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    background-color: var(--color-canvas);
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .lib-card:hover { border-color: var(--color-hairline-strong); transform: translateY(-1px); }
