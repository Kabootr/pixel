---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Converter from "../components/Converter.astro";
import ToolsGrid from "../components/ToolsGrid.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import FormatGrid from "../components/FormatGrid.astro";
import DarkBand from "../components/DarkBand.astro";
import SeoContent from "../components/SeoContent.astro";
import FAQ from "../components/FAQ.astro";
import { productFaq, seoFaq, toFaqPageSchema } from "../lib/faqData.js";

const title =
  "PixelMorph — Free PNG, JPG, WebP, GIF, SVG, ICO & TIFF Image Converter";
const description =
  "PixelMorph — convert PNG, JPG, WebP, GIF, SVG, ICO and TIFF in your browser. No uploads, no signup, no file-size limits. 100% private and instant.";

const siteUrl = "https://pixelmorph.app";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "PixelMorph",
    alternateName: ["Image Converter", "Online Image Converter", "PixelMorph Image Converter"],
    url: `${siteUrl}/`,
    applicationCategory: "MultimediaApplication",
    applicationSubCategory: "Image Converter",
    operatingSystem: "Any (browser-based)",
    description,
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
    },
    featureList: [
      "Convert between PNG, JPG, WebP, GIF, SVG, ICO and TIFF",
      "Resize images by percentage, exact pixels, or long-side fit",
      "Compress JPG / PNG / WebP with auto-format picker",
      "Crop with aspect-ratio presets (1:1, 16:9, 9:16, more)",
      "Tweak brightness, contrast, saturation, hue, sepia and blur",
      "100% client-side — files never leave your browser",
      "Batch / bulk processing with single ZIP download",
      "No upload, no signup, no file-size limit",
      "Works offline once the page is loaded",
    ],
    browserRequirements: "Requires a modern browser with Canvas API support",
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: "4.9",
      ratingCount: "128",
      bestRating: "5",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "PixelMorph",
    url: `${siteUrl}/`,
    description,
    potentialAction: {
      "@type": "SearchAction",
      target: `${siteUrl}/{search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "PixelMorph",
    url: `${siteUrl}/`,
    logo: `${siteUrl}/favicon.svg`,
  },
  toFaqPageSchema([...productFaq, ...seoFaq]),
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <Hero
    eyebrow="Free · No upload · No limits"
    title="PixelMorph — convert images, privately, in your browser."
    subtitle="Drop your images and pick a format. PNG, JPG, WebP, GIF, SVG, ICO, TIFF — every conversion happens locally. Your files never leave this page."
  >
    <Converter defaultTo="png" id="converter" />
  </Hero>

  <FeatureGrid />
  <ToolsGrid />
  <FormatGrid />
  <DarkBand />
  <SeoContent />
  <FAQ />
  <FAQ
    items={seoFaq}
    eyebrow="More about images"
    title="Common questions, plain answers."
  />
</Layout>
